<?xml version="1.0" encoding="utf-8"?>
<PassiveXmlRoot xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Passive ID="1">
    <Name>煙供給</Name>
    <Desc>幕の終了時、煙を1得る</Desc>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Uncommon</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Cost>2</Cost>
    <Script>TundraPassivePack_SupplySmoke</Script>
  </Passive>
  <Passive ID="2">
    <Name>煙転化</Name>
    <Desc>攻撃的中時、煙を3消耗してページを1枚引く。(1幕に1回)</Desc>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Uncommon</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Cost>2</Cost>
    <Script>TundraPassivePack_DrawSmoke</Script>
  </Passive>
  <Passive ID="3">
    <Name>脳を狂わせる煙</Name>
    <Desc>幕の開始時、煙が7以上あればパワーとクイックを3得る
7未満ならば、虚弱を2得て10の混乱ダメージを受ける

舞台開始時、煙を保有していないならば5得る</Desc>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Rare</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Cost>6</Cost>
    <Script>TundraPassivePack_BrainSmoke</Script>
  </Passive>
