<?xml version="1.0" encoding="utf-8"?>
<PassiveXmlRoot xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <Passive ID="1">
    <Name>煙供給</Name>
    <Desc>幕の終了時、煙を1得る</Desc>
    <Cost>2</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Uncommon</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_SupplySmoke</Script>
  </Passive>

  <Passive ID="2">
    <Name>煙転化</Name>
    <Desc>攻撃的中時、煙を3消耗してページを1枚引く。(1幕に1回)</Desc>
    <Cost>2</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Uncommon</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_DrawSmoke</Script>
  </Passive>

  <Passive ID="3">
    <Name>脳を狂わせる煙</Name>
    <Desc>幕の開始時、煙が7以上あればパワーとクイックを3得る
7未満ならば、虚弱を2得て10の混乱ダメージを受ける

舞台開始時、煙を保有していないならば5得る</Desc>
    <Cost>6</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Rare</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_BrainSmoke</Script>
  </Passive>

  <Passive ID="4">
    <Name>呼吸器直通</Name>
    <Desc>攻撃的中時、相手の煙を1消耗し、自身の煙を1増加
自身の煙が10なら、代わりにダメージ量増加を次の幕に1得る
(1幕に3回)</Desc>
    <Cost>3</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Rare</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_DrainSmoke</Script>
  </Passive>

  <Passive ID="5">
    <Name>吐き出した白煙</Name>
    <Desc>攻撃的中時、煙1を付与する</Desc>
    <Cost>4</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Uncommon</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_ExhaleSmoke</Script>
  </Passive>

  <Passive ID="6">
    <Name>現実不全症</Name>
    <Desc>幕の開始時、煙が9以上なら以下の効果から1つをランダムに有効化する
- 幕の開始時、パワー3・クイック5を得る
- 攻撃ダイスの最小値・最大値が4増加
- 回避ダイスの最小値が3減少・最大値が12増加
- この幕の間、威力の影響を受けない</Desc>
    <Cost>10</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Unique</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_UnrealSmoke</Script>
  </Passive>

  <Passive ID="7">
    <Name>順応するための呼気</Name>
    <Desc>幕の終了時、煙を全て消耗する。消耗した数値に応じて、次の幕に効果を得る(小数点切り捨て)
- (消耗した数値 ÷ 2)だけパワーと忍耐を得る。(最大2)
- (消耗した数値 ÷ 3)だけ光を回復する。(最大3)
- (消耗した数値 ÷ 5)だけページを引く。(最大2)</Desc>
    <Cost>2</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Rare</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_AdaptSmoke</Script>
  </Passive>

  <Passive ID="8">
    <Name>持っていけ！</Name>
    <Desc>幕の開始時、煙を10まで獲得する。(新たに獲得した値 × 5)だけ体力にダメージを受ける</Desc>
    <Cost>3</Cost>
    <Negative>false</Negative>
    <IsHide>false</IsHide>
    <Rarity>Uncommon</Rarity>
    <Lock>false</Lock>
    <CanGivePassive>true</CanGivePassive>
    <CanReceivePassive>false</CanReceivePassive>
    <InnerType>-1</InnerType>
    <Script>TundraPassivePack_TakehereSmoke</Script>
  </Passive>

</PassiveXmlRoot>
